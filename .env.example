# GetKiAgent — Environment Variables
# Copy to .env and fill in real values

FIRECRAWL_API_KEY=fc-...
ANTHROPIC_API_KEY=sk-ant-...

# n8n webhook: Gmail Draft erstellen (generate_outreach.py --draft)
N8N_WEBHOOK_URL=https://your-n8n.cloud/webhook/outreach-draft

# n8n webhook: Neue Discovery-URLs ins Sheet eintragen (discover_leads.py)
N8N_DISCOVERY_WEBHOOK=https://your-n8n.cloud/webhook/discovery-sync

# n8n webhook: Analysierte Leads ins Sheet eintragen (batch_analyze.py)
N8N_RESULTS_WEBHOOK=https://your-n8n.cloud/webhook/results-sync

# Google Sheets API — service account JSON (für clean_sheet.py)
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
GOOGLE_SHEET_ID=1OReC3rBa6bMImrw96dbTryW5LlB0SYWnbpn_t7x0-u0

# Gmail API — OAuth2 credentials (für cleanup_drafts.py)
# Download von Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GMAIL_CREDENTIALS_JSON=credentials.json
